# Solidity Skill Benchmark — Configuration
# Copy to .env and fill in your values.

# ── Eval provider (used by run_eval.py) ──────────────────────────────────
# Provider: "anthropic" or "openai" (auto-detected from model name if omitted)
#EVAL_PROVIDER=anthropic

# Model name
EVAL_MODEL=claude-sonnet-4-6-20250514

# API key (required — pick the one matching your provider)
#ANTHROPIC_API_KEY=sk-ant-...
#OPENAI_API_KEY=sk-...

# Custom OpenAI-compatible endpoint (Ollama, vLLM, Together, Azure, etc.)
#EVAL_BASE_URL=http://localhost:11434/v1
#EVAL_API_KEY=ollama

# ── Grading provider (used by grade.py) ──────────────────────────────────
# Defaults to the same as eval provider if not set.
#GRADING_MODEL=claude-sonnet-4-6-20250514
#GRADING_PROVIDER=anthropic
#GRADING_BASE_URL=
#GRADING_API_KEY=
